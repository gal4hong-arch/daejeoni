DATABASE_URL=sqlite:///./data/platform.db
# 멀티유저 영구 저장: Supabase Postgres URI (SQLAlchemy)
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase (프론트 Auth + supabase-py)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Dashboard > Settings > API > JWT Secret (Bearer 서명 검증). 비워 두면 로컬에서만 서명 생략(운영에서는 반드시 설정)
SUPABASE_JWT_SECRET=
# 로컬만: JWT 없이 X-Demo-User 헤더 허용
ALLOW_DEMO_USER_HEADER=false

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
OPENAI_API_KEY=

# 국가법령정보 OPEN API (법제처) — 가이드: https://open.law.go.kr/LSO/openApi/guideList.do
# OC는 open.law.go.kr 가입 후 발급 · https://open.law.go.kr/LSO/usr/usrOcInfoMod.do
# 한글주소 LAB: https://open.law.go.kr/LSO/lab/hangulAddr.do
LAW_GO_KR_OC=topazplus15
# LAW_GO_KR_BASE_URL=https://www.law.go.kr/DRF/lawSearch.do
# LAW_GO_KR_TARGET=aiSearch
# (제목·키워드 매칭 경로는 코드상 aiSearch를 우선 사용 — 법령정보지식베이스 지능형 법령검색 API)
# LAW_GO_KR_TARGET_FALLBACK=law
# LAW_GO_KR_TIMEOUT=25
# 본문 조회(검색 결과의 법령 ID로 추가 호출) — 예: lawService.do?OC=…&target=law&type=XML&ID=법령ID
LAW_GO_KR_SERVICE_URL=https://www.law.go.kr/DRF/lawService.do
LAW_GO_KR_SERVICE_TYPE=JSON
# 본법 본문: 현행(eflaw) 우선, 비면 law — 가이드 현행법령 본문 조회 API
# LAW_GO_KR_BODY_TARGET=eflaw
# LAW_GO_KR_BODY_TARGET_FALLBACK=law
# LAW_GO_KR_SERVICE_TYPE=XML
# LAW_GO_KR_SERVICE_MAX_IDS=2
# LAW_GO_KR_SERVICE_FETCH=true

# (선택) 자체 법령 검색 프록시 — LAW_GO_KR_OC가 비어 있을 때만 사용
LEGAL_API_BASE_URL=

SYSTEM_FALLBACK_MODEL=gpt-4o-mini

# PDF 업로드 최대 바이트(기본 48MB, 8~200MB로 클램프). nginx 등 업로드 한도와 함께 조정.
# RAG_PDF_MAX_BYTES=50331648
# PDF·URL 임베딩 시 본문 앞에 「문서 개요」청크 추가(LLM 요약, 실패 시 발췌). 끄려면 false.
# RAG_OUTLINE_CHUNK=true

# 쉼표 구분. 해당 이메일로 로그인해 PDF·URL·법령·직접청크 RAG를 등록하면 모든 사용자 검색 풀에 포함(shared_globally).
# RAG_ADMIN_EMAILS=gal4hong@gmail.com,other@example.com
